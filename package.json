{
  "name": "express-api-server",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "db:up": "docker compose up -d",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "prisma:generate": "prisma generate",
    "swagger:generate": "tsx scripts/generate-swagger.ts",
    "dev:setup": "npm run db:push && npm run prisma:generate",
    "predev": "npm run dev:setup",
    "dev": "npm run swagger:generate && tsx watch src/server.ts",
    "build": "tsc",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prestart": "npm run db:migrate && npm run prisma:generate && npm run build",
    "start": "node dist/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sudo-hassan-zahid/express-api-server.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/sudo-hassan-zahid/express-api-server/issues"
  },
  "homepage": "https://github.com/sudo-hassan-zahid/express-api-server#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "redis": "^5.12.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
